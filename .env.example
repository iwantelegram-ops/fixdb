# ─── Identitas Bot & Namespace Database ──────────────────────────────
#
# CODE_BOT menentukan 'nama' database bot ini.
# Semua koleksi (kalimat spam, regex, konfigurasi) dipisah berdasarkan kode ini.
#
# ATURAN:
#   - Dua bot dengan CODE_BOT SAMA → berbagi data yang sama (cocok untuk migrasi token)
#   - Dua bot dengan CODE_BOT BEDA di database yang sama → data tidak campur
#   - Boleh isi bebas: huruf, angka, underscore. Contoh: botku, myspam, nexus1
#   - Jika dikosongkan: bot tidak pakai prefix (data bercampur jika ada 2 bot di DB sama)
#
CODE_BOT=

# ─── Telegram API ───────────────────────────────────────────────────
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ─── Database (Pilih salah satu atau keduanya) ────────────────────
#
# [OPSI 1] MongoDB — jika URL ini ada dan bisa konek, MongoDB dipakai.
# Contoh: mongodb+srv://user:pass@cluster.mongodb.net/
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGO_DB_NAME=antispam
#
# [OPSI 1b] MULTI-CLUSTER MONGODB (Sharding) — untuk bot di banyak grup ramai.
# MongoDB free tier (M0) dibatasi ~100 operasi/detik. Jika satu cluster
# sudah terasa lambat/telat, tambahkan cluster gratis lain di sini.
# Setiap grup (chat_id) otomatis di-hash KONSISTEN ke salah satu cluster —
# grup yang sama akan selalu memakai cluster yang sama, walau bot direstart.
# Tidak wajib diisi — jika hanya MONGO_URL yang diisi, bot tetap berjalan
# normal dengan 1 cluster seperti biasa.
# MONGO_URL_2=mongodb+srv://user:pass@cluster2.mongodb.net/
# MONGO_URL_3=mongodb+srv://user:pass@cluster3.mongodb.net/
# (boleh ditambah terus MONGO_URL_4, MONGO_URL_5, ... tanpa batas —
#  WAJIB berurutan tanpa lubang nomor, berhenti otomatis di nomor kosong)
#
# [OPSI 2] SQLite — fallback otomatis jika MongoDB tidak ada/gagal.
# Path file database lokal di HP (Termux).
# Default: nexus_bot.db di folder bot.
# Contoh: SQLITE_PATH=/data/data/com.termux/files/home/nexus/nexus_bot.db
SQLITE_PATH=nexus_bot.db

# ─── Owner & Log ─────────────────────────────────────────────────────
OWNER_ID=123456789
LOG_CHANNEL=-100123456789

# LOG_OS: ID chat/channel khusus untuk log tindakan Security OS (mute/unmute).
# Isi dengan ID chat negatif (grup/channel) atau ID user owner.
# Kosongkan jika tidak ingin log terpisah.
# Contoh: LOG_OS=-1001234567890
LOG_OS=

# ─── Tampilan Welcome (opsional) ─────────────────────────────────────
# CHANNEL_OWNER: ID channel update (format -100...) yang ditampilkan
# sebagai link di pesan sambutan /start bot.
# Kosongkan jika tidak ingin ditampilkan.
# Contoh: CHANNEL_OWNER=-1001234567890
CHANNEL_OWNER=

# ─── Server (opsional, untuk health check) ───────────────────────────
PORT=8000

# ─── Security OS — Userbot (opsional) ─────────────────────────────────────────
#
# Fitur Security OS membutuhkan akun Telegram biasa (bukan bot) sebagai userbot.
# Userbot bertugas memantau obrolan SUARA dan menurunkan user yang bio-nya mengandung link.
#
# USERBOT_PHONE: Nomor HP akun Telegram yang akan dijadikan userbot.
# Format internasional, contoh: +628123456789
# Jika dikosongkan: fitur Security OS tidak tersedia (bot utama tetap jalan normal).
#
# PENTING:
#   - Akun ini harus sudah menjadi MEMBER di setiap grup yang memakai Security OS.
#   - Akun ini TIDAK PERLU menjadi admin.
#   - OTP login akan diminta ke OWNER_ID via bot biasa saat pertama kali dijalankan.
#   - Session disimpan ke file lokal + MongoDB (jika pakai Mongo) agar tidak login ulang.
#
# Contoh: USERBOT_PHONE=+628123456789
USERBOT_PHONE=
PANDUAN_OS="https://t.me/oslogchannel/52"
# ─── Bot Pemantau (monitor_bot_reference.py) ────────────────────────────────
#
# Bot pemantau WAJIB pakai MONGO_URL / SQLITE_PATH dan CODE_BOT yang SAMA
# dengan bot utama agar bisa berbagi database (collection bio_profiles).
#
# BOT_TOKEN_MONITOR: token bot pemantau (buat via @BotFather, BERBEDA d""ari BOT_TOKEN)
# BOT_TOKEN_MONITOR=

# SCAN_INTERVAL_MINUTES: seberapa sering bot pemantau scan ulang semua member grup
# Default: 30 menit. Lebih kecil = lebih realtime, tapi lebih banyak API call.
SCAN_INTERVAL_MINUTES=30

# BIO_RECHECK_SECS: minimum jeda sebelum re-check bio user yang sama
# Default: 600 detik (10 menit). Mencegah API spam untuk user yang sama.
# BIO_RECHECK_SECS=600

# BIO_TTL_SECS: berapa lama data bio disimpan di MongoDB sebelum dihapus otomatis.
# MongoDB TTL index akan hapus dokumen bio_profiles setelah waktu ini habis.
# Setiap kali user aktif (kirim pesan, typing, join VC) → TTL direset.
# Default: 300 detik (5 menit). Jika user tidak aktif 5 menit → data hilang.
# Saat user aktif lagi → bot pemantau fetch fresh dari Telegram API.
BIO_TTL_SECS=60

# BIO_DB_STALENESS_SECS: batas usia data bio sebelum dianggap "sudah lama"
# (data tetap dipakai, hanya dicatat sebagai stale di log)
# Default: 3600 detik (1 jam)
# BIO_DB_STALENESS_SECS=3600

# ─── Anti-FloodWait: Konfigurasi Rate-Limit & Cache Fill ──────────────────────
#
# BIO_QUEUE_DELAY: jeda (detik) antar GetFullUser di worker antrian per instance.
#   Default: 1.5 detik → maks ~40 req/menit per bot pemantau.
#   Naikkan jika masih kena FloodWait, turunkan jika mau lebih responsif.
# BIO_QUEUE_DELAY=1.5

# BIO_FILL_DELAY_SECS: jeda (detik) antar fetch di background fill loop.
#   Loop ini mengisi/merefresh cache untuk user yang baru-baru ini aktif
#   (typing / kirim pesan). Lebih lambat dari QUEUE_DELAY karena tidak mendesak.
#   Default: 3 detik.
# BIO_FILL_DELAY_SECS=3

# BIO_TTL_JITTER_SECS: rentang jitter TTL cache (detik) per grup.
#   Tiap grup mendapat offset TTL berbeda agar expires tidak barengan
#   lintas grup dan menimbulkan lonjakan fetch bersamaan.
#   Default: 60 detik. Offset = abs(chat_id) % JITTER (deterministik, bukan random).
# BIO_TTL_JITTER_SECS=60

# BIO_ACTIVE_WINDOW_SECS: window waktu (detik) seorang user dianggap "aktif"
#   oleh fill loop. User yang terakhir typing/kirim pesan di dalam window ini
#   akan dijaga cache-nya tetap fresh.
#   Default: 2× BIO_TTL_SECS.
# BIO_ACTIVE_WINDOW_SECS=600

# ─── Bengkel: Pool Token Backup untuk GetFullUser ─────────────────────────────
#
# Token cadangan (BotFather, BUKAN userbot) yang TIDAK terikat ke grup
# manapun — khusus dipakai sebagai pool bergantian untuk GetFullUser saat
# bot pemantau utama grup (MonitorInstance) belum aktif atau sedang
# FloodWait. Bot utama TIDAK PERNAH memanggil GetFullUser langsung.
#
# Tidak wajib diisi — jika kosong, fallback Bengkel tidak aktif (perilaku
# sama seperti sebelumnya: hanya MonitorInstance per-grup).
#
# TOKEN_BACKUP1=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TOKEN_BACKUP2=987654321:BBExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (boleh ditambah terus TOKEN_BACKUP3, TOKEN_BACKUP4, ... tanpa batas —
#  WAJIB berurutan tanpa lubang nomor, berhenti otomatis di nomor kosong.
#  Semakin banyak grup ramai, semakin banyak token backup yang disarankan.)

# WORKSHOP_TOKEN_MIN_GAP_SECS: jeda minimum (detik) antar pemakaian SATU
#   token backup yang sama, di luar FloodWait. Mencegah pool memukul token
#   yang sama bertubi-tubi hanya karena sedang paling idle.
#   Default: 1.0 detik.
# WORKSHOP_TOKEN_MIN_GAP_SECS=1.0

# WORKSHOP_FETCH_TIMEOUT_SECS: batas waktu total (detik) satu permintaan
#   GetFullUser melalui pool (gabungan semua percobaan token). Jika semua
#   token gagal/FloodWait sampai batas ini, permintaan dianggap gagal dan
#   bot utama melanjutkan tanpa data bio (dianggap aman/no-link).
#   Default: 12 detik.
# WORKSHOP_FETCH_TIMEOUT_SECS=12.0

